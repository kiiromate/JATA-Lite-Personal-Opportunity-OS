# JATA Lite runs with mocked AI by default and does not require API keys.
JATA_AI_PROVIDER=mock
JATA_AI_MODE=false

# Optional future providers. Leave blank unless explicitly enabling AI mode.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Local operator console.
JATA_API_HOST=127.0.0.1
JATA_API_PORT=4317
JATA_MAX_REQUESTS_PER_BATCH=5
JATA_MAX_OPPORTUNITIES_PER_RUN=20

# Future connector placeholders. Leave blank unless explicitly enabling a connector.
JATA_N8N_WEBHOOK_SECRET=

GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_ROOT_FOLDER_ID=

GOOGLE_SHEETS_CLIENT_ID=
GOOGLE_SHEETS_CLIENT_SECRET=
GOOGLE_SHEETS_SPREADSHEET_ID=
